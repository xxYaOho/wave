{
	"name": "wave",
	"version": "0.15.0",
	"description": "A CLI tool for generating design tokens",
	"type": "module",
	"module": "src/index.ts",
	"main": "src/index.ts",
	"bin": {
		"wave": "./src/index.ts"
	},
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "rm -f .*.bun-build && bun build ./src/index.ts --compile --outfile dist/wave && rm -f .*.bun-build",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --fix .",
		"check": "biome check --write .",
		"check:ci": "biome check .",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "bun run build && changeset publish"
	},
	"keywords": [
		"design-tokens",
		"cli",
		"style-dictionary"
	],
	"author": "ttao",
	"license": "MIT",
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"chroma-js": "^3.1.2",
		"commander": "^13.0.0",
		"js-yaml": "^4.1.0",
		"style-dictionary": "^5.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@changesets/cli": "^2.30.0",
		"@types/bun": "latest",
		"@types/chroma-js": "^3.1.0",
		"@types/js-yaml": "^4.0.9",
		"typescript": "^5"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
