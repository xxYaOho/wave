{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wave.tools/schemas/palette.json",
  "title": "Wave Palette Schema",
  "description": "Schema for Wave theme palette files",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "type": "object",
    "required": ["global"],
    "properties": {
      "global": {
        "type": "object",
        "required": ["color"],
        "properties": {
          "color": {
            "type": "object",
            "required": ["$type"],
            "properties": {
              "$type": {
                "type": "string",
                "enum": ["color"],
                "description": "Must be 'color' for palette files"
              },
              "$description": {
                "type": ["string", "null"],
                "description": "Optional description for the palette"
              },
              "$extensions": {
                "type": ["object", "null"],
                "description": "Optional extensions for additional metadata"
              }
            },
            "additionalProperties": {
              "type": "object",
              "description": "Color entries can be nested objects or leaf color tokens"
            }
          }
        }
      }
    }
  }
}
