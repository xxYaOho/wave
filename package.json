{
  "name": "wave",
  "version": "0.1.0",
  "description": "A CLI tool for generating design tokens",
  "type": "module",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "bin": {
    "wave": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --compile --outfile dist/wave",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "design-tokens",
    "cli",
    "style-dictionary"
  ],
  "author": "ttao",
  "license": "MIT",
  "dependencies": {
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
