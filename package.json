{
  "name": "wave",
  "version": "0.4.1",
  "description": "A CLI tool for generating design tokens",
  "type": "module",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "bin": {
    "wave": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --compile --outfile dist/wave",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["design-tokens", "cli", "style-dictionary"],
  "author": "ttao",
  "license": "MIT",
  "dependencies": {
    "chroma-js": "^3.1.2",
    "commander": "^13.0.0",
    "js-yaml": "^4.1.0",
    "style-dictionary": "^5.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/chroma-js": "^3.1.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
