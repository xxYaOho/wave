{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wave.tools/schemas/dimension.json",
  "title": "Wave Dimension Schema",
  "description": "Schema for Wave theme dimension files",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "type": "object",
    "required": ["global"],
    "properties": {
      "global": {
        "type": "object",
        "required": ["dimension"],
        "properties": {
          "dimension": {
            "type": "object",
            "description": "Dimension categories (e.g., alpha, rem, px)",
            "additionalProperties": {
              "type": "object",
              "description": "Dimension entries can be nested or leaf tokens"
            }
          }
        }
      }
    }
  }
}
